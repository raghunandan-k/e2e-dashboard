# Copy this file to .env and fill in the values. The .env file is gitignored.

# ----- Atlassian / Confluence -----
# Your Atlassian account email (the one you log into procoretech.atlassian.net with)
ATLASSIAN_EMAIL=your.name@procore.com

# Your Atlassian API token -- create one at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_TOKEN=your_atlassian_api_token_here

# The Confluence Cloud domain
ATLASSIAN_DOMAIN=procoretech.atlassian.net

# The Confluence page ID to update (from the URL: /pages/edit-v2/<PAGE_ID>)
CONFLUENCE_PAGE_ID=5346525200

# ----- E2E Test Runner -----
# Bearer token for the E2E Runner API. Get it from your browser session cookies
# or from someone on the e2e-test-runner-service team.
E2E_RUNNER_TOKEN=your_e2e_runner_bearer_token_here

# ----- Optional: Cutoff time for "latest" run -----
# Hour (0-23) in local time after which we consider the run "today's run".
# If no run exists after this hour, the script still shows the most recent run.
# Default: 17 (5 PM)
CUTOFF_HOUR=17

# ----- Optional: Timezone for 'today' comparison -----
# IANA timezone name. Runs whose created_at (converted to this TZ) matches
# today's date (in this TZ) are appended to the history. Everything else is
# skipped for that refresh. Default: Asia/Kolkata (IST, 5 PM refresh)
DASHBOARD_TZ=Asia/Kolkata

# ----- Optional: GitHub repo that hosts the dashboard workflow -----
# Used to build the "Run Now" link on the Confluence page. The link opens the
# GitHub Actions page where the user can trigger an on-demand refresh.
GITHUB_REPO_URL=https://github.com/raghunandan-k/e2e-dashboard
GITHUB_WORKFLOW_FILE=dashboard.yml
